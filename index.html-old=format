<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nancy Bethala-Frounjian | Systems Engineer & AI Infrastructure</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0e27;
            --bg-secondary: #111629;
            --bg-tertiary: #1a1f3a;
            --accent-primary: #00d9ff;
            --accent-secondary: #a78bfa;
            --accent-tertiary: #f97316;
            --text-primary: #f8fafc;
            --text-secondary: #cbd5e1;
            --text-tertiary: #94a3b8;
            --border-color: #334155;
        }

        body {
            font-family: 'IBM Plex Serif', serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(0, 217, 255, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(167, 139, 250, 0.06) 0%, transparent 50%),
                radial-gradient(circle at 40% 20%, rgba(249, 115, 22, 0.04) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        .nav-links {
            padding: 2rem 0 0 0;
            margin-bottom: 4rem;
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            animation: fadeInDown 0.8s ease;
        }

        .nav-links a {
            color: var(--accent-primary);
            text-decoration: none;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--accent-secondary);
        }

        header {
            padding: 4rem 0 3rem;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 4rem;
            animation: fadeInDown 0.8s ease;
        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: 1.1rem;
            color: var(--text-secondary);
            font-family: 'JetBrains Mono', monospace;
            font-weight: 500;
            letter-spacing: 0.05em;
            margin-bottom: 1.5rem;
        }

        .intro-text {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .foundation {
            background: linear-gradient(135deg, var(--bg-tertiary), var(--bg-secondary));
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 3rem;
            margin-bottom: 6rem;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        .foundation h2 {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            margin-bottom: 2rem;
            color: var(--accent-primary);
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .foundation-points {
            display: grid;
            gap: 1.5rem;
        }

        .foundation-point {
            padding-left: 2rem;
            border-left: 2px solid var(--accent-secondary);
            position: relative;
        }

        .foundation-point::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 6px;
            width: 10px;
            height: 10px;
            background: var(--accent-secondary);
            border-radius: 50%;
        }

        .foundation-point p {
            color: var(--text-secondary);
            font-size: 1.05rem;
            line-height: 1.7;
        }

        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin-bottom: 6rem;
            animation: fadeInUp 0.8s ease 0.4s both;
        }

        .tile {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
            display: flex;
            flex-direction: column;
        }

        .tile::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary), var(--accent-tertiary));
            opacity: 0;
            transition: opacity 0.3s;
        }

        .tile:hover {
            border-color: var(--accent-primary);
            background: var(--bg-tertiary);
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0, 217, 255, 0.1);
        }

        .tile:hover::before {
            opacity: 1;
        }

        .tile-label {
            font-family: 'Syne', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--accent-secondary);
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .tile-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            line-height: 1.3;
            color: var(--text-primary);
        }

        .tile-hook {
            font-size: 1rem;
            color: var(--accent-primary);
            margin-bottom: 1.5rem;
            font-weight: 500;
            line-height: 1.6;
        }

        .tile-section {
            margin-bottom: 1.5rem;
        }

        .tile-section-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-tertiary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .tile-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .tech-badge {
            background: rgba(0, 217, 255, 0.1);
            border: 1px solid var(--accent-primary);
            color: var(--accent-primary);
            padding: 0.4rem 0.8rem;
            border-radius: 4px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .tile-artifact {
            margin-top: auto;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .artifact-link {
            display: inline-block;
            padding: 0.75rem 1.25rem;
            background: rgba(0, 217, 255, 0.1);
            border: 1px solid var(--accent-primary);
            color: var(--accent-primary);
            text-decoration: none;
            border-radius: 6px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.2s;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .artifact-link:hover {
            background: var(--accent-primary);
            color: var(--bg-primary);
        }

        .artifact-quote {
            color: var(--text-tertiary);
            font-size: 0.9rem;
            margin-top: 0.75rem;
            font-style: italic;
            padding-left: 1rem;
            border-left: 2px solid var(--accent-secondary);
        }

        .tile-visual {
            background: var(--bg-tertiary);
            border: 1px dashed var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
            margin-top: 1.5rem;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-tertiary);
            text-align: center;
        }

        .architecture-diagram {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 1rem;
            align-items: center;
            margin-top: 1rem;
        }

        .diagram-box {
            background: rgba(0, 217, 255, 0.05);
            border: 1px solid var(--accent-primary);
            padding: 1rem;
            border-radius: 6px;
            text-align: center;
            font-size: 0.85rem;
        }

        .diagram-arrow {
            color: var(--accent-primary);
            font-size: 1.5rem;
        }

        .section {
            margin-bottom: 4rem;
            animation: fadeInUp 0.8s ease 0.5s both;
        }

        .section h2 {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--accent-primary);
            letter-spacing: -0.01em;
        }

        .skills-grid {
            display: grid;
            gap: 1.5rem;
        }

        .skill-item {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
        }

        .skill-item strong {
            color: var(--accent-primary);
            font-weight: 600;
        }

        .skill-item p {
            color: var(--text-secondary);
            margin-top: 0.5rem;
        }

        .projects-list {
            display: grid;
            gap: 1.5rem;
        }

        .project-item {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 1.5rem;
            transition: all 0.3s;
        }

        .project-item:hover {
            border-color: var(--accent-primary);
            background: var(--bg-tertiary);
        }

        .project-item a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .project-item a:hover {
            color: var(--accent-secondary);
        }

        .project-item p {
            color: var(--text-tertiary);
            font-size: 0.95rem;
            margin-top: 0.5rem;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        footer {
            border-top: 1px solid var(--border-color);
            padding: 3rem 0;
            text-align: center;
            color: var(--text-tertiary);
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            h1 { font-size: 2.5rem; }
            .subtitle { font-size: 1rem; }
            .tile-title { font-size: 1.4rem; }
            .foundation { padding: 2rem; }
            .foundation h2 { font-size: 1.5rem; }
            .architecture-diagram { grid-template-columns: 1fr; }
            .diagram-arrow { transform: rotate(90deg); }
            .nav-links { gap: 1rem; }
        }
    </style>
</head>
